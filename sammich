<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Clyde's Sandwich Stack</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      background: #f4f4f4;
      overflow: hidden;
      font-family: sans-serif;
    }
    canvas {
      display: block;
      background: #c2e0ff;
      width: 100vw;
      height: 100vh;
    }
  </style>
</head>
<body>
  <canvas id="game"></canvas>
  <script>
    // === Game Settings ===
    const LANDING_OFFSET_X = 20;
    const LANDING_OFFSET_Y = 228;
    const STACK_SPACING = 9;
    const CHARACTER_WIDTH = 320;
    const CHARACTER_HEIGHT = 320;
    const TOPPING_WIDTH = 100	;
    const TOPPING_HEIGHT = 100;
    const SANDWICH_LAYER_HEIGHT = 20;

    const canvas = document.getElementById("game");
    const ctx = canvas.getContext("2d");

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    let score = 0;
    const toppings = [];
    const sandwich = [];
    const toppingTypes = ["lettuce", "cheese", "tomato", "bacon"];

    const toppingColors = {
      lettuce: "green",
      cheese: "yellow",
      tomato: "red",
      bacon: "brown"
    };

    const toppingImages = {
      bacon: new Image(),
      lettuce: new Image(),
      tomato: new Image(),
      cheese: new Image()
    };
    toppingImages.bacon.src = "img/ham.png";
    toppingImages.lettuce.src = "img/lettuce.png";
    toppingImages.tomato.src = "img/tomato.png";
    toppingImages.cheese.src = "img/cheese.png";

    const clydeImg = new Image();
    clydeImg.src = "img/sammich_clyde.png";

    const clyde = {
      x: canvas.width / 2 - CHARACTER_WIDTH / 2,
      y: canvas.height - CHARACTER_HEIGHT,
      width: CHARACTER_WIDTH,
      height: CHARACTER_HEIGHT,
      baseSpeed: 2,
      speed: 2,
      maxSpeed: 10,
      acceleration: 0.2
    };

    const keys = {
      ArrowLeft: false,
      ArrowRight: false
    };

    document.addEventListener("keydown", (e) => {
      if (e.key in keys) keys[e.key] = true;
    });

    document.addEventListener("keyup", (e) => {
      if (e.key in keys) keys[e.key] = false;
      clyde.speed = clyde.baseSpeed;
    });

    function spawnTopping() {
      const type = toppingTypes[Math.floor(Math.random() * toppingTypes.length)];
      toppings.push({
        x: Math.random() * (canvas.width - TOPPING_WIDTH),
        y: 0,
        type: type,
        width: TOPPING_WIDTH,
        height: TOPPING_HEIGHT,
        speed: 3 + Math.random() * 2
      });
    }

    function drawClyde() {
      if (clydeImg.complete && clydeImg.naturalWidth !== 0) {
        ctx.drawImage(clydeImg, clyde.x, clyde.y, clyde.width, clyde.height);
      } else {
        ctx.fillStyle = "#444";
        ctx.fillRect(clyde.x, clyde.y, clyde.width, clyde.height);
      }
    }

    function drawToppings() {
      for (let t of toppings) {
        const img = toppingImages[t.type];
        if (img && img.complete && img.naturalWidth !== 0) {
          ctx.drawImage(img, t.x, t.y, t.width, t.height);
        } else {
          ctx.fillStyle = toppingColors[t.type];
          ctx.fillRect(t.x, t.y, t.width, t.height);
        }
      }
    }

    function getBreadPosition(stackIndex = 0) {
      return {
        x: clyde.x + LANDING_OFFSET_X,
        y: clyde.y + LANDING_OFFSET_Y - stackIndex * STACK_SPACING
      };
    }

    function drawSandwich() {
      for (let i = 0; i < sandwich.length; i++) {
        const part = sandwich[i];
        const img = toppingImages[part];
        const { x: breadX, y: breadY } = getBreadPosition(i);
        if (img && img.complete && img.naturalWidth !== 0) {
          ctx.drawImage(img, breadX, breadY, TOPPING_WIDTH, SANDWICH_LAYER_HEIGHT);
        } else {
          ctx.fillStyle = toppingColors[part];
          ctx.fillRect(breadX, breadY, TOPPING_WIDTH, SANDWICH_LAYER_HEIGHT);
        }
      }
    }

    function update() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (keys.ArrowLeft) {
        clyde.x -= clyde.speed;
        clyde.speed = Math.min(clyde.speed + clyde.acceleration, clyde.maxSpeed);
      } else if (keys.ArrowRight) {
        clyde.x += clyde.speed;
        clyde.speed = Math.min(clyde.speed + clyde.acceleration, clyde.maxSpeed);
      } else {
        clyde.speed = clyde.baseSpeed;
      }

      clyde.x = Math.max(0, Math.min(canvas.width - clyde.width, clyde.x));

      drawClyde();
      drawToppings();
      drawSandwich();

      for (let i = toppings.length - 1; i >= 0; i--) {
        let t = toppings[i];
        t.y += t.speed;

        let stackHeight = sandwich.length * STACK_SPACING;
        let { x: breadX, y: breadY } = getBreadPosition(sandwich.length);

        if (
          t.y + t.height >= breadY &&
          t.y <= breadY + SANDWICH_LAYER_HEIGHT &&
          t.x < breadX + TOPPING_WIDTH &&
          t.x + t.width > breadX
        ) {
          sandwich.push(t.type);
          score++;
          toppings.splice(i, 1);
        } else if (t.y > canvas.height) {
          toppings.splice(i, 1);
        }
      }

      ctx.fillStyle = "black";
      ctx.font = "20px sans-serif";
      ctx.fillText("Score: " + score, 10, 30);

      requestAnimationFrame(update);
    }

    setInterval(spawnTopping, 1000);
    update();
  </script>
</body>
</html>
